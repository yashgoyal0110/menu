generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id       String @id @default(cuid()) // internal id
  userId   String @unique // external id from auth provider
  name     String
  imageUrl String
  email    String @unique

  // Custom JWT auth (nullable: Clerk-provisioned rows won't have one).
  passwordHash String?

  // Email verification via one-time code (OTP).
  emailVerified Boolean   @default(false)
  otpCode       String?
  otpExpiresAt  DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  stores        Store[]
  subscription  Subscription?
  payments      Payment[]
}

model Logo {
  id        String       @id @default(cuid())
  name      String
  key       String       @unique
  url       String       @db.Text
  status    UploadStatus @default(PENDING)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  store   Store?  @relation("StoreLogo", fields: [storeId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  storeId String? @unique

  @@index([storeId])
}

model Banner {
  id        String       @id @default(cuid())
  name      String
  key       String       @unique
  url       String       @db.Text
  status    UploadStatus @default(PENDING)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  store   Store?  @relation("StoreBanner", fields: [storeId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  storeId String? @unique

  @@index([storeId])
}

model Store {
  id          String    @id @default(cuid())
  name        String    @unique
  description String    @db.Text
  address     String
  citySlug    String
  cityName    String
  province    String
  latitude    Float
  longitude   Float
  phone       String
  slug        String?   @unique
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  userId       String
  user         User          @relation(fields: [userId], references: [userId])
  logo         Logo?         @relation("StoreLogo")
  banner       Banner?       @relation("StoreBanner")
  products     Product[]
  businessHours BusinessHour[]
  availabilityResources AvailabilityResource[]
  availabilityExceptions AvailabilityException[]
  timezone     String        @default("UTC")
  availabilityEnabled Boolean @default(false)
  status       Status        @default(ACTIVE)

  @@index([userId])
  @@index([status])
  @@index([citySlug])
}

model BusinessHour {
  id          String  @id @default(cuid())
  storeId     String
  store       Store   @relation(fields: [storeId], references: [id], onDelete: Cascade)
  dayOfWeek   Int
  isClosed    Boolean @default(false)
  openMinute  Int     @default(540)
  closeMinute Int     @default(1020)

  @@unique([storeId, dayOfWeek])
  @@index([storeId])
}

model AvailabilityResource {
  id             String   @id @default(cuid())
  storeId        String
  store          Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  name           String
  singularLabel  String
  totalCapacity  Int
  availableNow   Int
  active         Boolean  @default(true)
  updatedAt      DateTime @updatedAt
  createdAt      DateTime @default(now())

  @@index([storeId])
}

model AvailabilityException {
  id          String   @id @default(cuid())
  storeId     String
  store       Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  date        DateTime @db.Date
  isClosed    Boolean  @default(true)
  openMinute  Int?
  closeMinute Int?
  note        String?

  @@unique([storeId, date])
  @@index([storeId, date])
}

model Product {
  id          String    @id @default(cuid())
  name        String
  price       Int
  description String    @db.Text
  category    Category  @default(Repairs)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  storeId     String
  store       Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId], name: "storeId")
}

model Payment {
  id              String   @id @default(cuid())
  paymentId       String?  @unique
  provider        String
  userId          String
  user            User     @relation(fields: [userId], references: [userId])
  subscriptionId  String?
  subscription    Subscription? @relation(fields: [subscriptionId], references: [id])
  status          String
  merchantOrderId String?
  amount          Float
  currency        String?
  paymentMethod   String?
  metadata        Json?
  rawPayload      Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
  @@index([subscriptionId])
  @@index([paymentId])
}

model Subscription {
  id                 String             @id @default(cuid())
  userId             String             @unique
  planType           PlanType
  status             SubscriptionStatus @default(PENDING)
  mpPreapprovalId    String?            @unique
  stripeCustomerId     String?
  stripeSubscriptionId String? @unique
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  nextPaymentDate    DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  user     User      @relation(fields: [userId], references: [userId])
  payments Payment[]

  @@index([userId])
  @@index([status])
  @@index([mpPreapprovalId])
}

enum Status {
  ACTIVE
  INACTIVE
}

enum Category {
  Repairs
  Plans
  AddOns
}

enum UploadStatus {
  PENDING
  PROCESSING
  FAILED
  SUCCESS
}

enum PlanType {
  BASIC
  PRO
  ENTERPRISE
}

enum SubscriptionStatus {
  ACTIVE
  INACTIVE
  CANCELLED
  EXPIRED
  PENDING
}
